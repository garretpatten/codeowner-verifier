{
  "name": "codeowner-verifier",
  "author": "Garret Patten",
  "version": "1.3",
  "description": "A GitHub Action that verifies that modified files are owned by codeowners",
  "private": true,
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garretpatten/codeowner-verifier.git"
  },
  "license": "",
  "homepage": "https://github.com/garretpatten/codeowner-verifier#readme",
  "scripts": {
    "build": "ncc build src/action.ts --minify",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint:prettier": "prettier --check .",
    "lint:md": "markdownlint-cli2",
    "lint:yaml": "yamllint -c .yamllint.yaml ."
  },
  "dependencies": {
    "@actions/core": "^1.10.0",
    "ignore": "^7.0.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@vercel/ncc": "^0.38.4",
    "jest": "^29.7.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  }
}
